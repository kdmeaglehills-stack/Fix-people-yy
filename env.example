const imageInput=document.getElementById('imageInput'),detectBtn=document.getElementById('detectBtn'),fixBtn=document.getElementById('fixBtn'),downloadBtn=document.getElementById('downloadBtn'),promptInput=document.getElementById('promptInput'),optionsCountInput=document.getElementById('optionsCount'),resolutionInput=document.getElementById('resolution'),paddingPercentInput=document.getElementById('paddingPercent'),featherPixelsInput=document.getElementById('featherPixels'),statusText=document.getElementById('statusText'),groupsPanel=document.getElementById('groupsPanel'),canvas=document.getElementById('previewCanvas'),ctx=canvas.getContext('2d');let detector=null,originalImage=null,originalDataUrl=null,detections=[],groups=[],generatedGroups=[];imageInput.addEventListener('change',onImageUpload);detectBtn.addEventListener('click',detectPeople);fixBtn.addEventListener('click',fixAllPeople);downloadBtn.addEventListener('click',downloadFlattened);
async function onImageUpload(e){const f=e.target.files?.[0];if(!f)return;setStatus('Loading image...');originalDataUrl=await fileToDataUrl(f);originalImage=await loadImage(originalDataUrl);canvas.width=originalImage.naturalWidth||originalImage.width;canvas.height=originalImage.naturalHeight||originalImage.height;detections=[];groups=[];generatedGroups=[];groupsPanel.innerHTML='';drawOriginal();detectBtn.disabled=false;fixBtn.disabled=true;downloadBtn.disabled=true;setStatus('Image loaded. Click Detect People.')}
async function detectPeople(){try{setStatus('Loading people detector...');if(!detector)detector=await cocoSsd.load();setStatus('Detecting people...');const p=await detector.detect(originalImage);detections=p.filter(x=>x.class==='person'&&x.score>=.45).map((x,i)=>({id:`person-${i+1}`,x:x.bbox[0],y:x.bbox[1],width:x.bbox[2],height:x.bbox[3],score:x.score}));groups=groupNearbyPeople(detections);drawDetectionPreview();fixBtn.disabled=groups.length===0;setStatus(`Detected ${detections.length} people. Created ${groups.length} group crop(s).`)}catch(e){setStatus(`Detection error: ${e.message||e}`)}}
function groupNearbyPeople(b){const v=new Set,r=[];for(let i=0;i<b.length;i++){if(v.has(i))continue;const s=[i],m=[];v.add(i);while(s.length){const ci=s.pop(),c=b[ci];m.push(c);for(let j=0;j<b.length;j++){if(v.has(j))continue;if(shouldGroup(c,b[j])){v.add(j);s.push(j)}}}r.push({id:`group-${r.length+1}`,members:m,box:unionBox(m)})}return r}
function shouldGroup(a,b){const e=45,ax1=a.x-e,ay1=a.y-e,ax2=a.x+a.width+e,ay2=a.y+a.height+e,bx1=b.x-e,by1=b.y-e,bx2=b.x+b.width+e,by2=b.y+b.height+e;return!(ax2<bx1||bx2<ax1||ay2<by1||by2<ay1)}
function unionBox(m){const x1=Math.min(...m.map(x=>x.x)),y1=Math.min(...m.map(x=>x.y)),x2=Math.max(...m.map(x=>x.x+x.width)),y2=Math.max(...m.map(x=>x.y+x.height));return{x:Math.round(x1),y:Math.round(y1),width:Math.round(x2-x1),height:Math.round(y2-y1)}}
async function fixAllPeople(){try{fixBtn.disabled=true;downloadBtn.disabled=true;groupsPanel.innerHTML='';setStatus('Sending crops to Magnific. Keep this tab open...');const r=await fetch('/api/fix-people',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({imageDataUrl:originalDataUrl,groups,optionsCount:Number(optionsCountInput.value||1),prompt:promptInput.value,resolution:resolutionInput.value,paddingPercent:Number(paddingPercentInput.value||40)/100})}),d=await r.json();if(!r.ok)throw new Error(d.error||'Server request failed.');generatedGroups=d.groups.map(g=>({...g,selectedIndex:0}));renderGeneratedGroups();await drawComposite();downloadBtn.disabled=false;setStatus('Done. Choose the best option for each group, then download.')}catch(e){setStatus(`Generation error: ${e.message||e}`)}finally{fixBtn.disabled=false}}
function renderGeneratedGroups(){groupsPanel.innerHTML='';generatedGroups.forEach((g,gi)=>{const c=document.createElement('div');c.className='groupCard';c.innerHTML=`<div class="groupHeader"><strong>${g.label}</strong><span class="meta">${g.aspectRatio} | ${g.box.width}×${g.box.height}</span></div><div class="thumbs"></div>`;const t=c.querySelector('.thumbs');g.options.forEach((o,oi)=>{const b=document.createElement('button');b.className=`thumbBtn ${oi===g.selectedIndex?'active':''}`;b.innerHTML=`<img src="${o}" alt="Option ${oi+1}">`;b.onclick=async()=>{generatedGroups[gi].selectedIndex=oi;renderGeneratedGroups();await drawComposite()};t.appendChild(b)});groupsPanel.appendChild(c)})}
function drawOriginal(){ctx.clearRect(0,0,canvas.width,canvas.height);ctx.drawImage(originalImage,0,0,canvas.width,canvas.height)}
function drawDetectionPreview(){drawOriginal();groups.forEach((g,i)=>{const b=g.box;ctx.strokeStyle='#3ddb91';ctx.fillStyle='rgba(61,219,145,.15)';ctx.lineWidth=3;ctx.fillRect(b.x,b.y,b.width,b.height);ctx.strokeRect(b.x,b.y,b.width,b.height);ctx.fillStyle='#3ddb91';ctx.font='20px Arial';ctx.fillText(`G${i+1}`,b.x+8,b.y+24)})}
async function drawComposite(){drawOriginal();for(const g of generatedGroups){const o=await loadImage(g.options[g.selectedIndex]);drawImageCoverWithFeather(ctx,o,g.box.x,g.box.y,g.box.width,g.box.height,Number(featherPixelsInput.value||0));ctx.strokeStyle='#76a9ff';ctx.lineWidth=2;ctx.strokeRect(g.box.x,g.box.y,g.box.width,g.box.height)}}
function drawImageCoverWithFeather(t,img,x,y,w,h,f){const off=document.createElement('canvas');off.width=w;off.height=h;const o=off.getContext('2d'),iw=img.naturalWidth||img.width,ih=img.naturalHeight||img.height,scale=Math.max(w/iw,h/ih),sw=w/scale,sh=h/scale,sx=(iw-sw)/2,sy=(ih-sh)/2;o.drawImage(img,sx,sy,sw,sh,0,0,w,h);if(f>0)applyRectFeather(o,w,h,f);t.drawImage(off,x,y)}
function applyRectFeather(t,w,h,f){f=Math.min(f,Math.floor(w/2),Math.floor(h/2));if(f<=0)return;const m=document.createElement('canvas');m.width=w;m.height=h;const c=m.getContext('2d');c.fillStyle='black';c.fillRect(0,0,w,h);c.globalCompositeOperation='destination-in';let g=c.createLinearGradient(0,0,f,0);g.addColorStop(0,'rgba(0,0,0,0)');g.addColorStop(1,'rgba(0,0,0,1)');c.fillStyle=g;c.fillRect(0,0,f,h);g=c.createLinearGradient(w,0,w-f,0);g.addColorStop(0,'rgba(0,0,0,0)');g.addColorStop(1,'rgba(0,0,0,1)');c.fillStyle=g;c.fillRect(w-f,0,f,h);g=c.createLinearGradient(0,0,0,f);g.addColorStop(0,'rgba(0,0,0,0)');g.addColorStop(1,'rgba(0,0,0,1)');c.fillStyle=g;c.fillRect(0,0,w,f);g=c.createLinearGradient(0,h,0,h-f);g.addColorStop(0,'rgba(0,0,0,0)');g.addColorStop(1,'rgba(0,0,0,1)');c.fillStyle=g;c.fillRect(0,h-f,w,f);t.globalCompositeOperation='destination-in';t.drawImage(m,0,0);t.globalCompositeOperation='source-over'}
function downloadFlattened(){const a=document.createElement('a');a.href=canvas.toDataURL('image/png');a.download='fix-people-final.png';a.click()}
function fileToDataUrl(file){return new Promise((res,rej)=>{const r=new FileReader;r.onload=()=>res(r.result);r.onerror=rej;r.readAsDataURL(file)})}
function loadImage(src){return new Promise((res,rej)=>{const i=new Image;i.onload=()=>res(i);i.onerror=rej;i.src=src})}
function setStatus(m){statusText.textContent=m}
